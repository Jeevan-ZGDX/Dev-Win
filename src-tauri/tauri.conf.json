{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "devdash",
  "version": "0.1.0",
  "identifier": "com.devdash.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DevDash",
        "width": 420,
        "height": 680,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "skipTaskbar": false,
        "visible": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/tray-idle.ico",
      "iconAsTemplate": false,
      "menuOnLeftClick": false
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
